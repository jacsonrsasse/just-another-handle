{
  "name": "just-another-handle",
  "version": "0.0.1",
  "description": "Just another wrapper for Handlebars",
  "main": "./dist/index.cjs",
  "publishConfig": {
    "access": "public"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "Handlebars"
  ],
  "author": "Jacson Sasse",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "handlebars": "^4.7.8"
  }
}
